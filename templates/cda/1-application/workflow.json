{
  "id": "cda-apply-cert-flow",
  "name": "Submit Application",
  "version": 1,
  "nodes": [
    {
      "id": "start",
      "type": "START"
    },
    {
      "id": "applicant_submission",
      "type": "TASK",
      "task_template_id": "cda-apply-cert--user-input",
      "output_mapping": {
        "userform": "userform",
        "userform.requested_salmonella_cert": "requested_salmonella_cert",
        "userform.requested_quality_cert": "requested_quality_cert"
      }
    },
    {
      "id": "reviewer_review",
      "type": "TASK",
      "task_template_id": "cda-apply-cert--reviewer-review",
      "input_mapping": {
