        "reviewerform.application_id": "application_id",
        "reviewerform.payment_amount": "payment_amount"
      }
    },
    {
      "id": "end",
      "type": "END"
    }
  ],
  "edges": [
    {
      "id": "e_start",
      "source_id": "start",
      "target_id": "applicant_submission"
    },
    {
      "id": "e_submission_to_review",
      "source_id": "applicant_submission",
