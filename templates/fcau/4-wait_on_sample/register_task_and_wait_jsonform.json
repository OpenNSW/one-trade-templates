{
  "id": "fcau-sample-wait--reviewer-form",
  "title": "Consignment Sample Receipt Confirmation",
  "schema": {
    "type": "object",
    "properties": {
      "sample_tag_id": {
        "type": "string",
        "title": "Issued Sample Tag ID",
        "example": "SMP-FCAU-2026-948"
      },
      "received_at": {
        "type": "string",
        "format": "date-time",
        "title": "Date & Time of Receipt",
        "example": "2026-06-18T09:30:00Z"
      },
      "receipt_outcome": {
        "type": "string",
        "title": "Sample Receipt Outcome",
        "enum": [
          "confirmed",
          "rejected"
        ],
        "default": "confirmed"
      },
      "notes": {
        "type": "string",
        "title": "Notes",
        "example": "Sample arrived intact; logged into chain-of-custody register."
      }
    },
    "required": [
      "sample_tag_id",
      "received_at",
      "receipt_outcome"
    ]
  },
  "uischema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/sample_tag_id"
      },
      {
        "type": "Control",
        "scope": "#/properties/received_at"
      },
      {
        "type": "Control",
        "scope": "#/properties/receipt_outcome"
      },
      {
        "type": "Control",
        "scope": "#/properties/notes",
        "options": {
          "multi": true
        }
      }
    ]
  }
}