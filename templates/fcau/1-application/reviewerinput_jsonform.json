{
  "id": "fcau-apply-health-cert--reviewer-form",
  "title": "Application Assessment Review",
  "schema": {
    "type": "object",
    "properties": {
      "review_outcome": {
        "type": "string",
        "title": "Application Assessment Outcome",
        "enum": [
          "approve",
          "reject",
          "needs_more_info"
        ],
        "default": "approve",
        "example": "approve"
      },
      "reference_number": {
        "type": "string",
        "title": "FCAU Application Reference Number",
        "example": "REF-FCAU-2026-00481"
      },
      "rejection_reason": {
        "type": "string",
        "title": "Comments / Feedback / Deficiencies (if Reject/Needs Info)",
        "example": "Consignment food grade manufacturing details verified; application is complete and approved for fee assessment."
      }
    },
    "required": [
      "review_outcome",
      "reference_number"
    ]
  },
  "uischema": {
    "type": "VerticalLayout",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/review_outcome"
      },
      {
        "type": "Control",
        "scope": "#/properties/reference_number"
      },
      {
        "type": "Control",
        "scope": "#/properties/rejection_reason",
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": {
              "const": "needs_more_info"
            }
          }
        }
      }
    ]
  }
}
